{
  "permissions": {
    "allow": [
      "Bash(npm audit:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_snapshot",
      "Bash(npm run:*)",
      "Bash(git:*)",
      "mcp__github-personal__create_issue",
      "Bash(gh issue:*)",
      "Bash(npx tsc:*)",
      "mcp__github-personal__create_pull_request",
      "mcp__github-personal__get_pull_request",
      "Bash(gh pr:*)",
      "mcp__github-personal__merge_pull_request",
      "mcp__github-personal__add_issue_comment",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_close",
      "Bash(npx skills:*)",
      "Bash(npx:*)",
      "WebSearch",
      "mcp__atlassian-jira__jira_get",
      "mcp__atlassian-jira__jira_post",
      "WebFetch(domain:skills.sh)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "Bash(npm install:*)",
      "Bash(curl:*)",
      "mcp__playwright__browser_type"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"cd 'C:/devel/Claude Code Tests/employee-directory' && npm run build --silent 2>&1; BUILD=$?; npm run lint --silent 2>&1; LINT=$?; if [ $BUILD -ne 0 ] || [ $LINT -ne 0 ]; then echo 'BLOCKED: build or lint failed. Fix errors before committing.'; exit 1; fi\""
          }
        ]
      }
    ]
  }
}
